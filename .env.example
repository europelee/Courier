# 隧道穿透服务 - 环境变量配置示例
# 复制此文件为 .env，然后根据你的环境修改参数

# ============================================================================
# 后端服务配置
# ============================================================================

# 服务监听端口
PORT=8080

# 服务域名（用于生成公网 URL）
SERVER_DOMAIN=localhost:8080

# 数据库配置
DATABASE_URL=sqlite:./tunnel.db

# 日志级别（debug, info, warn, error）
LOG_LEVEL=info

# 最大并发连接数
MAX_CONNECTIONS=1000

# 连接超时（秒）
CONNECTION_TIMEOUT=30

# ============================================================================
# HTTPS/TLS 配置
# ============================================================================

# HTTPS 监听端口
HTTPS_PORT=8443

# SSL 证书路径
SSL_CERT_PATH=./certs/server.crt

# SSL 密钥路径
SSL_KEY_PATH=./certs/server.key

# 自动续期证书（yes/no）
AUTO_RENEW_CERT=no

# ============================================================================
# 认证配置
# ============================================================================

# 管理员密码
ADMIN_PASSWORD=

# JWT 密钥（用于令牌签名）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 令牌过期时间（小时）
TOKEN_EXPIRY=24

# ============================================================================
# 前端配置
# ============================================================================

# 前端监听端口
FRONTEND_PORT=3000

# 前端构建模式（development/production）
NODE_ENV=development

# API 基础 URL
VITE_API_BASE_URL=http://localhost:8080

# ============================================================================
# 存储配置
# ============================================================================

# 存储类型（sqlite/mysql/postgresql）
STORAGE_TYPE=sqlite

# SQLite 数据库文件路径
SQLITE_PATH=./tunnel.db

# MySQL 连接字符串
MYSQL_URL=mysql://user:password@localhost:3306/tunnel_db

# PostgreSQL 连接字符串
POSTGRESQL_URL=postgresql://user:password@localhost:5432/tunnel_db

# ============================================================================
# 功能开关
# ============================================================================

# 启用 WebSocket
ENABLE_WEBSOCKET=true

# 启用实时日志
ENABLE_REAL_TIME_LOGS=true

# 启用性能监控
ENABLE_MONITORING=true

# 启用自动备份
ENABLE_AUTO_BACKUP=false

# 备份间隔（小时）
BACKUP_INTERVAL=24

# ============================================================================
# 限流配置
# ============================================================================

# 启用限流
ENABLE_RATE_LIMIT=true

# 每分钟最大请求数
REQUESTS_PER_MINUTE=1000

# 每小时最大请求数
REQUESTS_PER_HOUR=50000

# ============================================================================
# Docker 配置
# ============================================================================

# 容器时区
TZ=Asia/Shanghai

# 容器重启策略
RESTART_POLICY=unless-stopped
